// prisma/schema.prisma
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id    String     @id @default(cuid())
  email String     @unique
  name  String?
  password String?
  image String?
  role  String     @default("USER")
  plan  String     @default("FREE")

  // Stripe
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Relations
  accounts  Account[]
  sessions  Session[]
  sheets    Sheet[]
  searches  Search[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([stripeCustomerId])
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// FICHES DE PRÉDICATION
// ============================================

model Sheet {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Contenu
  title         String
  theme         String?
  mainVerses    String?
  outline       String?
  notes         String?
  searchResults String?

  // Metadata
  tags          String?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([updatedAt])
}

// ============================================
// RECHERCHES
// ============================================

model Search {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Requête
  query     String
  mode      String
  filters   String?

  // Résultats
  results   String

  // Performance
  latencyMs Int?

  // Timestamps
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([mode])
}

// ============================================
// DOCUMENTS (Sources indexées)
// ============================================

model Document {
  id        String   @id @default(cuid())

  // Identification
  title     String
  source    String

  // Contenu
  content   String
  metadata  String?

  // Indexation
  vectorId  String?
  indexed   Boolean  @default(false)

  // Fichier original
  filePath  String?
  fileType  String?
  fileSize  Int?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([indexed])
  @@index([createdAt])
}

// ============================================
// RATE LIMITING
// ============================================

model RateLimit {
  id         String   @id @default(cuid())
  userId     String
  action     String
  count      Int      @default(0)
  resetAt    DateTime

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, action])
  @@index([userId])
  @@index([resetAt])
}
